@page "/"
@inject AppLocalizationService LocalizationService
<!-- 区域 1：顶部核心巨幕区 -->
<div class="aot-hero">
    <div>
        <span class="badge badge-error text-xs font-black tracking-widest uppercase px-2.5 py-1 mb-3">
            @GetText("HeroTag")
        </span>
        <h1 class="text-3xl  lg:text-5xl font-black uppercase text-white leading-tight mb-3">
            @GetText("HeroTitle")
        </h1>
        <p class="text-xs opacity-80 leading-relaxed max-w-2xl mb-6">
            @GetText("HeroDesc")
        </p>
        <div class="flex flex-wrap gap-2">
            <button class="btn btn-xs md:btn-sm btn-primary font-bold px-5">@GetText("BtnIntel")</button>
            <button class="btn btn-xs md:btn-sm btn-outline btn-secondary ">@GetText("BtnGallery")</button>
        </div>
    </div>
</div>

<!-- 區域 2：調查兵團精銳作戰檔案  -->
<div class="flex flex-col gap-2 mt-6">
    <h3 class="text-sm md:text-base lg:text-lg font-black uppercase tracking-widest text-primary flex items-center gap-2">
        <span>⚔️</span> @GetText("SectionTitle")
    </h3>

    <div class="aot-card-grid">
        @foreach (var member in _characterDatabase)
        {
            <div class="aot-card">
                <div class="aot-card-body">
                    <div class="flex justify-between items-start gap-2 mb-2">
                        <div>
                            <h4 class="font-black text-base md:text-lg lg:text-xl text-white">@GetText(member.NameKey)</h4>
                            <span class="text-xs text-secondary">@GetText(member.TitleKey)</span>
                        </div>
                        <div class="badge badge-xs md:badge-sm badge-outline badge-error font-bold">@member.Rank</div>
                    </div>
                    <p class="text-xs md:text-xs lg:text-sm opacity-75 min-h-[54px] leading-relaxed">
                        @GetText(member.BioKey)
                    </p>
                    <div class="divider my-2.5 opacity-5"></div>
                    <div class="flex justify-between items-center text-xxs">
                        <div><span class="opacity-70">@GetText("StatKills"):</span> <span class="font-black text-error">@member.Kills</span></div>
                        <div><span class="opacity-70">@GetText("StatWits"):</span> <span class="font-black text-success">@member.Wits/10</span></div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- 新增区域 3：九大巨人能力图谱面板   -->
<div class="flex flex-col gap-2">
    <h3 class="text-sm md:text-base lg:text-lg font-black uppercase tracking-widest text-primary flex items-center gap-2">
        <span>🧬</span> @GetText("TitanSectionTitle")
    </h3>
    
    <!-- 三端自适应网格容器 (手机1列，平板2列，台式PC3列) -->
    <div class="aot-titan-grid">
        @foreach (var titan in _titanDatabase)
        {
            <div class="aot-titan-card">
                <div class="aot-titan-badges">
                    <img src="/img/titans/@titan.TypeBadge"
                         class="aot-titan-badge"
                         alt="@titan.TypeBadge" />
                    @* Add a second badge here when needed:
                    <img src="/img/titans/@titan.SecondBadge"
                         class="aot-titan-badge"
                         alt="@titan.SecondBadge" />
                    *@
                </div>

                <!-- 头部基本信息 -->
                <div class="flex justify-between items-start mb-3" style="position: relative; border: 0px solid red">
                    <div style ="position: relative; border: 0px solid blue">
                        <h4 class="font-black text-base md:text-lg lg:text-xl text-white">@GetText(titan.NameKey)</h4>
                        <span class="text-xs text-error uppercase tracking-wider">@GetText(titan.HeightKey)</span>
                    </div>

                </div>

                <!-- 描述文本 -->
                <p class="text-xs lg:text-sm opacity-75 leading-relaxed min-h-[50px] mb-4">
                    @GetText(titan.DescKey)
                </p>

                <div class="divider my-2 opacity-5"></div>

                <!-- 量化三维能力雷达进度条 (使用 daisyUI 原生 Progress 组件) -->
                <div class="flex flex-col gap-2.5 text-xs">
                    <!-- 力量指标 -->
                    <div>
                        <div class="flex justify-between mb-1">
                            <span class="">@GetText("ParamPower")</span>
                            <span class="text-primary font-bold">@titan.Power%</span>
                        </div>
                        <progress class="progress progress-primary w-full h-1" value="@titan.Power" max="100"></progress>
                    </div>

                    <!-- 速度指标 -->
                    <div>
                        <div class="flex justify-between mb-1">
                            <span class="">@GetText("ParamSpeed")</span>
                            <span class="text-secondary font-bold">@titan.Speed%</span>
                        </div>
                        <progress class="progress progress-secondary w-full h-1" value="@titan.Speed" max="100"></progress>
                    </div>

                    <!-- 硬度/特殊能力指标 -->
                    <div>
                        <div class="flex justify-between  mb-1">
                            <span class="">@GetText("ParamArmor")</span>
                            <span class="text-accent font-bold">@titan.Armor%</span>
                        </div>
                        <progress class="progress progress-accent w-full h-1" value="@titan.Armor" max="100"></progress>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
<!-- 區域 4：兵團戰術裝備與牆外調查資產 -->
<div class="flex flex-col gap-2 mt-6">
    <h3 class="text-sm md:text-base lg:text-lg font-black uppercase tracking-widest text-primary flex items-center gap-2">
        <span>⚙️</span> @GetText("GearSectionTitle")
    </h3>

    <div class="aot-gear-grid">
        @foreach (var gear in _gearDatabase)
        {
            <div class="aot-gear-card">
                <!-- 裝備頭部 -->
                <div class="flex justify-between items-center mb-2">
                    <h4 class="font-black text-sm md:text-base lg:text-lg text-white">@GetText(gear.NameKey)</h4>
                    <div class="badge badge-xs md:badge-sm badge-outline badge-accent font-bold shrink-0">@gear.ClassBadge</div>
                </div>
                
                <!-- 技術分類 (全寬展示，防止折行) -->
                <div class="text-xs text-secondary uppercase tracking-wider mb-3">
                    @GetText(gear.TechKey)
                </div>

                <!-- 裝備描述 -->
                <p class="text-xs md:text-sm opacity-75 leading-relaxed min-h-[50px] mb-4">
                    @GetText(gear.DescKey)
                </p>

                <div class="divider my-2 opacity-5"></div>

                <!-- 戰術規格參數 -->
                <div class="flex justify-between items-center text-xxs opacity-85">
                    <div><span class="">@GetText("SpecWeight"):</span> <span class="text-white">@gear.WeightSpec</span></div>
                    <div><span class="">@GetText("SpecRisk"):</span> <span class="text-error font-bold">@gear.RiskLevel</span></div>
                </div>
            </div>
        }
    </div>
</div>

<!-- 区域 5：编年史时间轴区 -->
<div class="flex flex-col gap-2 mt-6">
    <h3 class="text-sm md:text-base lg:text-lg font-black uppercase tracking-widest text-primary flex items-center gap-2">
        <span>⏳</span> @GetText("TimelineHeader")
    </h3>
    <div class="aot-timeline-card">
        <ul class="timeline timeline-vertical timeline-compact">
            <li>
                <div class="timeline-middle text-error">📍</div>
                <div class="timeline-end bg-base-200 p-3 rounded-xl border border-neutral-content/5 text-[11px] md:text-xs mb-4 w-full">
                    <time class="font-mono font-black text-secondary text-xs md:text-sm">845 年</time>
                    <div class="font-bold text-white mt-1 text-xs md:text-sm">@GetText("Time1Title")</div>
                    <p class="opacity-70 mt-1">@GetText("Time1Desc")</p>
                </div>
                <hr class="bg-primary/30" />
            </li>
            <li>
                <hr class="bg-primary/30" />
                <div class="timeline-middle text-warning">📍</div>
                <div class="timeline-end bg-base-200 p-3 rounded-xl border border-neutral-content/5 text-[11px] md:text-xs w-full">
                    <time class="font-mono font-black text-secondary text-xs md:text-sm">854 年</time>
                    <div class="font-bold text-white mt-1 text-xs md:text-sm">@GetText("Time2Title")</div>
                    <p class="opacity-70 mt-1">@GetText("Time2Desc")</p>
                </div>
            </li>
        </ul>
    </div>
</div>


