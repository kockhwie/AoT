@page "/"
@inject AppLocalizationService LocalizationService
<!-- 区域 1：顶部核心巨幕区 -->
<div class="aot-hero">
    <div>
        <span class="badge badge-error text-xs font-black tracking-widest uppercase px-2.5 py-1 mb-3">
            @LocalizationService.GetString("HeroTag")
        </span>
        <h1 class="text-3xl  lg:text-4xl font-black uppercase text-white leading-tight mb-3">
            @LocalizationService.GetString("HeroTitle")
        </h1>
        <p class="text-xs opacity-80 leading-relaxed max-w-2xl mb-6">
            @LocalizationService.GetString("HeroDesc")
        </p>
        <div class="flex flex-wrap gap-2">
            <button class="btn btn-xs md:btn-sm btn-primary font-bold px-5">@LocalizationService.GetString("BtnIntel")</button>
            <button class="btn btn-xs md:btn-sm btn-outline btn-secondary ">@LocalizationService.GetString("BtnGallery")</button>
        </div>
    </div>
</div>

<!-- 區域 2：調查兵團精銳作戰檔案  -->
<div class="flex flex-col gap-2 mt-6">
    <h3 class="text-sm md:text-base lg:text-lg font-black uppercase tracking-widest text-primary flex items-center gap-2">
        <i class="ti ti-swords"></i> @LocalizationService.GetString("SectionTitle")       
    </h3>
    
    <div class="aot-card-grid">
        @foreach (var member in _characterDatabase)
        {
            <div class="aot-card">
                <div class="aot-card-body">
                    <div class="flex justify-between items-start gap-2 mb-2">
                        <div>
                            <h4 class="font-black text-base md:text-lg lg:text-xl text-white">@LocalizationService.GetString(member.NameKey)</h4>
                            <span class="text-xs text-secondary">@LocalizationService.GetString(member.TitleKey)</span>
                        </div>
                        <div class="badge badge-xs md:badge-sm badge-outline badge-error font-bold">@member.Rank</div>
                    </div>
                    <p class="text-xs md:text-xs lg:text-sm opacity-75 min-h-[54px] leading-relaxed">
                        @LocalizationService.GetString(member.BioKey)
                    </p>
                    <div class="divider my-2.5 opacity-5"></div>
                    <div class="flex justify-between items-center text-xxs">
                        <div><span class="opacity-70">@LocalizationService.GetString("StatKills"):</span> <span class="font-black text-error">@member.Kills</span></div>
                        <div><span class="opacity-70">@LocalizationService.GetString("StatWits"):</span> <span class="font-black text-success">@member.Wits/10</span></div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- 新增区域 3：九大巨人能力图谱面板   -->
<div class="flex flex-col gap-2">
    <h3 class="text-sm md:text-base lg:text-lg font-black uppercase tracking-widest text-primary flex items-center gap-2">
        <i class="ti ti-dna-2"></i> @LocalizationService.GetString("TitanSectionTitle")
    </h3>
    
    <!-- 三端自适应网格容器 (手机1列，平板2列，台式PC3列) -->
   

        <div class="titan-registry-grid">
 
            @foreach (var titan in _titanDatabase)
            {
 
                <div class="hype-card-container">
                <div class="titan-hype-card  theme-@titan.Theme">

                        <!-- Holographic Flare Overlay Sheets -->
                        <div class="holo-foil-layer"></div>
                        <div class="hologram-scanlines"></div>

                        <!-- Top Row Meta Registry Labels -->
                        <div class="meta-registry-row">
                            <span class="registry-serial"></span>
                            <div class="class-node">@LocalizationService.GetString(titan.Theme)</div>
                        </div>

                        <!-- Clean Full-Width Header Title -->
                        <div class="chassis-header">
                            <div class="title-container">
                                <h2 class="titan-display-title">@LocalizationService.GetString(titan.NameKey)</h2>
                            </div>
                        </div>

                        <!-- Centerpiece Immersive Image Window -->
                        <div class="artwork-glass-frame">
                            <div class="glass-reflection"></div>
                            <img src="/img/titans/@titan.TypeBadge" class="chassis-art" alt="@titan.TypeBadge" />
                            <div class="laser-gold-trim"></div>
                        </div>

                        <!-- Spec Analytics Dashboard Grid -->
                        <div class="specs-dashboard-grid">
                            <div class="spec-node">                                 
                            </div>
                            <div class="spec-node align-right"> 
                                <div class="node-hdr">@LocalizationService.GetString(titan.HeightKey)</div>                                
                            </div>
                        </div>                        

                        <!-- Lore Paragraph Text Box -->
                        <div class="lore-summary-area">
                            <p class="lore-text-body">
                            @LocalizationService.GetString(titan.DescKey)
                            </p>
                        </div>

                        <div class="chassis-divider"></div>

                        <div class="flex flex-col gap-2.5 text-xs">
                            <!-- 力量指标 -->
                            <div>
                                <div class="flex justify-between mb-1">
                                    <span class="">@LocalizationService.GetString("ParamPower")</span>
                                    <span class="text-primary font-bold">@titan.Power%</span>
                                </div>
                                <progress class="progress progress-primary w-full h-1" value="@titan.Power" max="100"></progress>
                            </div>

                            <!-- 速度指标 -->
                            <div>
                                <div class="flex justify-between mb-1">
                                    <span class="">@LocalizationService.GetString("ParamSpeed")</span>
                                    <span class="text-secondary font-bold">@titan.Speed%</span>
                                </div>
                                <progress class="progress progress-secondary w-full h-1" value="@titan.Speed" max="100"></progress>
                            </div>

                            <!-- 硬度/特殊能力指标 -->
                            <div>
                                <div class="flex justify-between  mb-1">
                                    <span class="">@LocalizationService.GetString("ParamArmor")</span>
                                    <span class="text-accent font-bold">@titan.Armor%</span>
                                </div>
                                <progress class="progress progress-accent w-full h-1" value="@titan.Armor" max="100"></progress>
                            </div>
                        </div>

                    </div>
                </div>


               

            }
        </div>
</div>





<!-- 區域 4：兵團戰術裝備與牆外調查資產 -->
<div class="flex flex-col gap-2 mt-6">
    <h3 class="text-sm md:text-base lg:text-lg font-black uppercase tracking-widest text-primary flex items-center gap-2">
        <i class="ti ti-settings"></i>@LocalizationService.GetString("GearSectionTitle")
    </h3>

    <div class="aot-gear-grid">
        @foreach (var gear in _gearDatabase)
        {
            <div class="aot-gear-card">
                <!-- 裝備頭部 -->
                <div class="flex justify-between items-center mb-2">
                    <h4 class="font-black text-sm md:text-base lg:text-lg text-white">@LocalizationService.GetString(gear.NameKey)</h4>
                    <div class="badge badge-xs md:badge-sm badge-outline badge-accent font-bold shrink-0">@LocalizationService.GetString(gear.ClassBadge) </div>
                </div>
                
                <!-- 技術分類 (全寬展示，防止折行) -->
                <div class="text-xs text-secondary uppercase tracking-wider mb-3">
                    @LocalizationService.GetString(gear.TechKey)
                </div>

                <!-- 裝備描述 -->
                <p class="text-xs md:text-sm opacity-75 leading-relaxed min-h-[50px] mb-4">
                    @LocalizationService.GetString(gear.DescKey)
                </p>

                <div class="divider my-2 opacity-5"></div>

                <!-- 戰術規格參數 -->
                <div class="flex justify-between items-center text-xxs opacity-85">
                    <div><span class="">@LocalizationService.GetString("SpecWeight"):</span> <span class="text-white">@gear.WeightSpec</span></div>
                    <div><span class="">@LocalizationService.GetString("SpecRisk"):</span> <span class="text-error font-bold">@gear.RiskLevel</span></div>
                </div>
            </div>
        }
    </div>
</div>

<!-- 区域 5：编年史时间轴区 -->
<div class="flex flex-col gap-2 mt-6">
    <h3 class="text-sm md:text-base lg:text-lg font-black uppercase tracking-widest text-primary flex items-center gap-2">
        <i class="ti ti-clock"></i> @LocalizationService.GetString("TimelineHeader")
    </h3>
    <div class="aot-timeline-card">
        <ul class="timeline timeline-vertical timeline-compact">
            <li>
                <div class="timeline-middle text-error">📍</div>
                <div class="timeline-end bg-base-200 p-3 rounded-xl border border-neutral-content/5 text-[11px] md:text-xs mb-4 w-full">
                    <time class="font-mono font-black text-secondary text-xs md:text-sm">845 年</time>
                    <div class="font-bold text-white mt-1 text-xs md:text-sm">@LocalizationService.GetString("Time1Title")</div>
                    <p class="opacity-70 mt-1">@LocalizationService.GetString("Time1Desc")</p>
                </div>
                <hr class="bg-primary/30" />
            </li>
            <li>
                <hr class="bg-primary/30" />
                <div class="timeline-middle text-warning">📍</div>
                <div class="timeline-end bg-base-200 p-3 rounded-xl border border-neutral-content/5 text-[11px] md:text-xs w-full">
                    <time class="font-mono font-black text-secondary text-xs md:text-sm">854 年</time>
                    <div class="font-bold text-white mt-1 text-xs md:text-sm">@LocalizationService.GetString("Time2Title")</div>
                    <p class="opacity-70 mt-1">@LocalizationService.GetString("Time2Desc")</p>
                </div>
            </li>
        </ul>
    </div>
</div>

<script>

document.querySelectorAll('.hype-card-container').forEach(container => {
const card = container.querySelector('.titan-hype-card');
const foil = container.querySelector('.holo-foil-layer');

container.addEventListener('mousemove', (e) => {
const rect = container.getBoundingClientRect();

// Calculate cursor position relative to the container (value between 0 and 1)
const x = (e.clientX - rect.left) / rect.width;
const y = (e.clientY - rect.top) / rect.height;

// Convert to tilt degrees (Max tilt: 12deg X, 12deg Y)
const tiltX = (0.5 - y) * 24;
const tiltY = (x - 0.5) * 24;

// Apply the 3D tilt transformation to the card
card.style.transform = `translateY(-10px) rotateX(${tiltX}deg) rotateY(${tiltY}deg) translateZ(0)`;

// Map cursor positions directly onto the background gradient positions of the foil
if (foil) {
foil.style.backgroundPosition = `${x * 100}% ${y * 100}%`;
}
});

// Smoothly snap back to origin configuration on mouse leave
container.addEventListener('mouseleave', () => {
card.style.transform = 'translateY(0px) rotateX(0deg) rotateY(0deg) translateZ(0)';
if (foil) {
foil.style.backgroundPosition = '0% 0%';
}
});
});
</script>

